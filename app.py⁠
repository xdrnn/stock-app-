import streamlit as st
from analyzer import get_stock_news, analyze_news_for_longterm

st.markdown(
    """
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <style>
        .block-container { padding-top: 2rem !important; padding-bottom: 2rem !important; }
        .stButton>button { width: 100%; r_border-radius: 10px; }
    </style>
    """,
    unsafe_allow_html=True
)

st.title("实时 장기투자 AI 추천봇")

stock_dict = {
    "애플 (AAPL)": "AAPL",
    "마이크로소프트 (MSFT)": "MSFT",
    "구글 (GOOGL)": "GOOGL",
    "테슬라 (TSLA)": "TSLA",
    "엔비디아 (NVDA)": "NVDA"
}

selected_name = st.selectbox("분석할 종목을 고르세요", list(stock_dict.keys()))
ticker = stock_dict[selected_name]

if st.button(f"🔍 {selected_name} 뉴스 분석하기"):
    with st.spinner("AI가 가치 분석 중..."):
        try:
            news = get_stock_news(ticker)
            if news:
                st.success("📊 AI 장기 가치 투자 평가")
                analysis_result = analyze_news_for_longterm(news)
                st.markdown(analysis_result)
                st.markdown("---")
                st.subheader("📰 원문 뉴스")
                for n in news[:3]:
                    st.markdown(f"🔗 [{n['title']}]({n['link']})")
            else:
                st.warning("최신 뉴스를 가져오지 못했습니다.")
        except Exception as e:
            st.error("오류가 발생했습니다. 잠시 후 다시 시도해주세요.")
